// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  name                String?
  password            String
  role                UserRole   @default(FREE)
  roleVersion         Int        @default(0)
  emailVerified       Boolean    @default(false)
  verificationOtp     String?
  verificationOtpExpiry DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  candidate           CandidateProfile?
  skillProfile        CandidateSkillProfile?
  resumes             Resume[]
  githubProfile       GithubProfile?
  interviews          InterviewSession[]
  feedbacks           Feedback[]
}

model CandidateProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  githubUsername    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model Resume {
  id                String   @id @default(cuid())
  userId            String
  version           Int      @default(1)
  objectKey         String
  extractedText     String   @db.Text
  uploadedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
  interviews        InterviewSession[]

  @@unique([userId, version])
  @@index([userId])
}

model GithubProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  username          String
  summary           String   @db.Text
  languages         Json
  projects          Json
  analyzedAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])
}

model CandidateSkillProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  communication     Json     @default("[]")
  technicalDepth    Json     @default("[]")
  problemSolving    Json     @default("[]")
  leadership        Json     @default("[]")
  commonPatterns    Json     @default("[]")
  patternSignals    Json     @default("[]")
  failurePatterns   Json     @default("[]")
  traitHistory      Json     @default("[]")
  identityTraits    Json     @default("{}")
  mostImprovedSkill String?
  weakestSkill      String?
  generatedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model InterviewSession {
  id                  String         @id @default(cuid())
  userId              String
  status              InterviewStatus
  interviewStyle      InterviewStyle @default(PROFESSIONAL)
  interviewDepth      InterviewDepth @default(STANDARD)
  companyId           String?
  companyName         String?
  roleTitle           String?
  interviewRound      String?
  startedAt           DateTime?
  endedAt             DateTime?
  overallScore        Float?
  communicationScore  Float?
  technicalScore      Float?
  problemSolvingScore Float?
  durationSeconds     Int?
  position            String?
  jobDescription      String?        @db.Text
  resumeId            String?
  resume              Resume?        @relation(fields: [resumeId], references: [id])
  summary             InterviewSummary?
  turns               InterviewTurn[]
  createdAt           DateTime       @default(now())
  user                User           @relation(fields: [userId], references: [id])
}

model InterviewTurn {
  id              String   @id @default(cuid())
  interviewId     String
  orderNumber     Int
  questionText    String   @db.Text
  answerText      String   @db.Text
  questionStartMs Int?
  answerStartMs   Int?
  answerEndMs     Int?
  score           Float?
  feedback        String?  @db.Text
  createdAt       DateTime @default(now())
  interview       InterviewSession   @relation(fields: [interviewId], references: [id])
}

model InterviewSummary {
  id                    String   @id @default(cuid())
  interviewId           String   @unique
  summary               String   @db.Text
  strengths             Json
  weaknesses            Json
  improvementAreas      Json
  recommendedTopics     Json
  resumeStrengths       Json
  resumeWeaknesses      Json
  generatedAt           DateTime @default(now())
  interview             InterviewSession @relation(fields: [interviewId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  rating    Int
  category  String   @default("General")
  message   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum UserRole {
  FREE
  PRO
  ADMIN
}

enum InterviewStatus {
  CREATED
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum InterviewStyle {
  SUPPORTIVE
  PROFESSIONAL
  CHALLENGING
  BAR_RAISER
}

enum InterviewDepth {
  STANDARD
  PROBING
  CHALLENGE
  BAR_RAISER
}
