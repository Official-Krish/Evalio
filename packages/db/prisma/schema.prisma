// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String?
  password              String
  role                  UserRole               @default(FREE)
  roleVersion           Int                    @default(0)
  emailVerified         Boolean                @default(false)
  verificationOtp       String?
  verificationOtpExpiry DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  candidate             CandidateProfile?
  skillProfile          CandidateSkillProfile?
  resumes               Resume[]
  githubProfile         GithubProfile?
  interviews            InterviewSession[]
  dsaSessions           DsaSession[]
  feedbacks             Feedback[]
  seenSdQuestions       SdQuestionSeenByUser[]
}

model CandidateProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  githubUsername String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Resume {
  id            String             @id @default(cuid())
  userId        String
  version       Int                @default(1)
  objectKey     String
  extractedText String             @db.Text
  uploadedAt    DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id])
  interviews    InterviewSession[]

  @@unique([userId, version])
  @@index([userId])
}

model GithubProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  username   String
  summary    String   @db.Text
  languages  Json
  projects   Json
  analyzedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model CandidateSkillProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  communication     Json     @default("[]")
  technicalDepth    Json     @default("[]")
  problemSolving    Json     @default("[]")
  leadership        Json     @default("[]")
  commonPatterns    Json     @default("[]")
  patternSignals    Json     @default("[]")
  failurePatterns   Json     @default("[]")
  traitHistory      Json     @default("[]")
  identityTraits    Json     @default("{}")
  mostImprovedSkill String?
  weakestSkill      String?
  generatedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model InterviewSession {
  id                  String             @id @default(cuid())
  userId              String
  status              InterviewStatus
  mode                InterviewMode      @default(VOICE)
  interviewStyle      InterviewStyle     @default(PROFESSIONAL)
  interviewDepth      InterviewDepth     @default(STANDARD)
  companyId           String?
  companyName         String?
  roleTitle           String?
  roleCategory        String?
  interviewRound      String?
  startedAt           DateTime?
  endedAt             DateTime?
  overallScore              Float?
  overallConfidence         Float?
  communicationScore        Float?
  communicationConfidence   Float?
  technicalScore            Float?
  technicalConfidence       Float?
  problemSolvingScore       Float?
  problemSolvingConfidence  Float?
  momentum                  String?
  momentumSlope             Float?
  discrepancies             Json?
  durationSeconds           Int?
  position            String?
  jobDescription      String?            @db.Text
  resumeId            String?
  resume              Resume?            @relation(fields: [resumeId], references: [id])
  summary             InterviewSummary?
  turns               InterviewTurn[]
  dsaSession          DsaSession?
  finalDiagram        Json?
  canvasGraphHistory  Json?              @default("[]")
  createdAt           DateTime           @default(now())
  user                User               @relation(fields: [userId], references: [id])
}

model SystemDesignQuestion {
  id                  String                @id @default(cuid())
  companyName         String?
  position            String?
  roleCategory        String?
  interviewDepth      InterviewDepth
  interviewStyle      InterviewStyle
  title               String
  description         String                @db.Text
  fullBreakdown       String                @db.Text
  backupTitle         String?
  backupDescription   String?               @db.Text
  backupFullBreakdown String?               @db.Text
  lastUsedAt          DateTime?
  createdAt           DateTime              @default(now())
  seenBy              SdQuestionSeenByUser[]

  @@index([companyName, position, roleCategory])
}

model SdQuestionSeenByUser {
  userId      String
  questionId  String
  seenAt      DateTime  @default(now())
  interviewId String

  user     User                  @relation(fields: [userId], references: [id])
  question SystemDesignQuestion  @relation(fields: [questionId], references: [id])

  @@id([userId, questionId])
  @@index([userId])
}

model LeetCodeQuestion {
  id             String             @id @default(cuid())
  leetcodeId     Int                @unique
  title          String
  slug           String
  difficulty     LeetCodeDifficulty
  acceptanceRate Float
  frequency      Float              @default(0)
  companies      String[]
  description    String?            @db.Text
  expectedTopics String[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model DsaSession {
  id           String            @id @default(cuid())
  interviewId  String?           @unique
  userId       String
  status       String            @default("IN_PROGRESS")
  language     String            @default("python")
  currentIndex Int               @default(0)
  timeTaken    Int?
  createdAt    DateTime          @default(now())
  submittedAt  DateTime?
  user         User              @relation(fields: [userId], references: [id])
  interview    InterviewSession? @relation(fields: [interviewId], references: [id])
  problems     DsaProblem[]

  @@index([userId])
}

model DsaProblem {
  id              String     @id @default(cuid())
  dsaSessionId    String
  index           Int
  title           String
  slug            String
  difficulty      String
  description     String     @db.Text
  code            String?    @db.Text
  codeSnapshots   Json?
  currentPhase    String     @default("understanding")
  phasesCompleted String[]
  score           Float?
  feedback        String?    @db.Text
  complexity      String?
  timeTaken       Int?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  dsaSession      DsaSession @relation(fields: [dsaSessionId], references: [id])

  @@index([dsaSessionId])
}

model InterviewTurn {
  id              String           @id @default(cuid())
  interviewId     String
  orderNumber     Int
  questionText    String           @db.Text
  answerText      String           @db.Text
  questionStartMs Int?
  answerStartMs   Int?
  answerEndMs     Int?
  score           Float?
  weight          Float?
  evidence        String?          @db.Text
  feedback        String?          @db.Text
  createdAt       DateTime         @default(now())
  interview       InterviewSession @relation(fields: [interviewId], references: [id])
}

model InterviewSummary {
  id                String           @id @default(cuid())
  interviewId       String           @unique
  summary           String           @db.Text
  strengths         Json
  weaknesses        Json
  improvementAreas  Json
  recommendedTopics Json
  resumeStrengths   Json
  resumeWeaknesses  Json
  generatedAt       DateTime         @default(now())
  interview         InterviewSession @relation(fields: [interviewId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  rating    Int
  category  String   @default("General")
  message   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum UserRole {
  FREE
  PRO
  ADMIN
}

enum InterviewStatus {
  CREATED
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum InterviewStyle {
  SUPPORTIVE
  PROFESSIONAL
  CHALLENGING
  BAR_RAISER
}

enum InterviewDepth {
  STANDARD
  PROBING
  CHALLENGE
  BAR_RAISER
}

enum InterviewMode {
  VOICE
  LIVE_CODE
  LIVE_CANVAS
  DISCUSSION
}

enum LeetCodeDifficulty {
  EASY
  MEDIUM
  HARD
}
